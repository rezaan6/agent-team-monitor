# Copy to .env.local for local dev. In production, set these in the Vercel
# project's Environment Variables panel. Never commit .env.local.

# Supabase project URL — e.g. https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon public key — safe to ship to the browser; read-only access
# is gated by the RLS policies in supabase/migrations/0001_init.sql.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service-role key — SERVER ONLY. Bypasses RLS. Do NOT expose to
# the browser. Used exclusively by /api/* route handlers for writes.
SUPABASE_SERVICE_ROLE_KEY=

# Seed-only credentials. Read by scripts/seed-users.mjs when first
# provisioning the admin + test users. Not read by the running app.
ADMIN_EMAIL=
ADMIN_PASSWORD=
TEST_EMAIL=test@demo.local
TEST_PASSWORD=demo-1234
